# Copy this file to .env and fill in the campus you're working on.
# Do NOT commit .env to git.

# 2-letter campus code, lowercase — becomes part of the proxy URL
# e.g. bx → cuny-bx.primo.exlibrisgroup.com
CAMPUS=bx

# Exact name of the folder under primo-explore/custom/
# Must match an existing view on the proxy server
VIEW_CODE=CUNY_BX
